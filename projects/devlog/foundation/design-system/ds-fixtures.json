  "StatCard": {
    "html": "<div data-slot=\"card\" class=\"bg-card text-card-foreground flex flex-col gap-6 rounded-xl border py-6 shadow-sm\"><div data-slot=\"card-header\" class=\"@container/card-header auto-rows-min grid-rows-[auto_auto] gap-1.5 px-6 has-data-[slot=card-action]:grid-cols-[1fr_auto] [.border-b]:pb-6 flex flex-row items-center justify-between pb-2\"><h3 data-slot=\"card-title\" class=\"text-sm font-medium text-muted-foreground\"></h3></div><div data-slot=\"card-content\" class=\"px-6\"><div class=\"text-2xl font-bold\"></div><div class=\"mt-1 flex items-center gap-1.5\"><!-- Trend badge --></div></div></div>"
