{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Write(output/foundation/design-system/ds-allowlist.md)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/ds-guide-validate.py",
            "args": ["${tool_input.file_path}"],
            "statusMessage": "ds-allowlist.md 형식 검증 중..."
          },
          {
            "type": "command",
            "if": "Edit(output/foundation/design-system/ds-allowlist.md)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/ds-guide-validate.py",
            "args": ["${tool_input.file_path}"],
            "statusMessage": "ds-allowlist.md 형식 검증 중..."
          }
        ]
      }
    ]
  }
}
