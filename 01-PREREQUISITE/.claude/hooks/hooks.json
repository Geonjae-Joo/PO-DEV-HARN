{
  "description": "PREREQUISITE layer hooks — design-guide.md 저장 시 자동 검증 (저장 이벤트 훅). design page lint는 design-page-builder 스킬이 직접 호출하므로 skills/design-page-builder/scripts/ 에 위치.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Write(output/foundation/design-system/design-guide.md)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/ds-guide-validate.py",
            "args": ["${tool_input.file_path}"],
            "statusMessage": "design-guide.md 형식 검증 중..."
          },
          {
            "type": "command",
            "if": "Edit(output/foundation/design-system/design-guide.md)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/ds-guide-validate.py",
            "args": ["${tool_input.file_path}"],
            "statusMessage": "design-guide.md 형식 검증 중..."
          }
        ]
      }
    ]
  }
}
